# Copy to .env for local Docker / VPS. Never commit a real .env.

PORT=4700
DATA_DIR=/data
ROUTE47_ADMIN_API_KEY=change-me-to-a-long-random-string
ROUTE47_PUBLIC_URL=https://route47.your-domain.example
ROUTE47_HOSTING_MODE=docker

# Firebase Admin (project route47-admin) — required for background FCM.
# On Railway, prefer Base64 (multiline JSON pastes often get corrupted):
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccount.json"))
# ROUTE47_FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
# Or raw one-line JSON:
# ROUTE47_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
