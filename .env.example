# Copy to .env for local Docker / VPS. Never commit a real .env.

PORT=4700
DATA_DIR=/data
ROUTE47_ADMIN_API_KEY=change-me-to-a-long-random-string
ROUTE47_PUBLIC_URL=https://route47.your-domain.example
ROUTE47_HOSTING_MODE=docker

# Vendor only — full JSON from Firebase project route47-admin
# (Project settings → Service accounts → Generate new private key).
# Leave unset for customer DIY deploys; set on Route47-managed servers.
# ROUTE47_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
